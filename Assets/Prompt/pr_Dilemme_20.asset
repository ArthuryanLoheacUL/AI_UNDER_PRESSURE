  m_EditorClassIdentifier: Assembly-CSharp::Prompt
  senderName: Capt. Varen
  message: "J\u2019ai accept\xE9 de d\xE9tourner une partie de l\u2019\xE9quipage
    pour aider l\u2019\xE9quipe scientifique, mais les ing\xE9nieurs se plaignent
    d\xE9j\xE0 du manque de main-d\u2019\u0153uvre. J\u2019ai maintenu l\u2019ordre
    pour l\u2019instant, mais les tensions montent. Dois-je maintenir la redistribution
    ?"
  responseOptions:
  - optionText: Maintenir
    responseAIText: "R\xE9partition maintenue. Les priorit\xE9s scientifiques sont
      renforc\xE9es."
    responseUserText: "Les ing\xE9nieurs vont mal le prendre\u2026"
    ressourceGain: -8
    frustrationGain: 4
  - optionText: "R\xE9tablir"
    responseAIText: "\xC9quipage r\xE9assign\xE9 \xE0 leurs postes d\u2019origine."
    responseUserText: "Merci. On commen\xE7ait \xE0 \xEAtre d\xE9bord\xE9s."
