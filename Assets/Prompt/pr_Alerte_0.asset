  m_Name: pr_Alerte_0
  m_EditorClassIdentifier: Assembly-CSharp::Prompt
  senderName: Capt. Collin
  message: "J\u2019ai relu le rapport de d\xE9rive et constat\xE9 que notre trajectoire
    a gliss\xE9 de trois degr\xE9s pendant la nuit. J\u2019ai r\xE9ussi \xE0 contenir
    la panique de l\u2019\xE9quipe, mais si nous ne corrigeons pas maintenant, nous
    allons entrer dans une zone de rayonnement instable. Pouvez-vous relancer la
    correction de cap ?"
  responseOptions:
  - optionText: Corriger
    responseAIText: "Correction appliqu\xE9e. La trajectoire est redevenue stable."
    responseUserText: "Bien. On \xE9vite le pire pour cette fois."
    ressourceGain: -12
    frustrationGain: -5
  - optionText: Maintenir
    responseAIText: "Trajectoire maintenue. Aucune correction effectu\xE9e."
    responseUserText: Vous nous faites vraiment prendre des risques inutiles.
    ressourceGain: 3
    frustrationGain: 9
  timer: 0
  timerMax: 0
